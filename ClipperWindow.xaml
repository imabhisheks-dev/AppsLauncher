<Window x:Class="AppsLauncher.ClipperWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clipper"
        Icon="/AppsLauncher;component/launcher.ico"
        Height="420" Width="660"
        MinWidth="420" MinHeight="250"
        Background="#F3F3F3"
        FontFamily="Consolas"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="True">

    <Window.Resources>

        <!-- Base button -->
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AddButton"    TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Background" Value="#0078D4"/>
        </Style>
        <Style x:Key="RemoveButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Background" Value="#C42B1C"/>
        </Style>
        <Style x:Key="SaveButton"   TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Background" Value="#5C6BC0"/>
        </Style>

        <!-- Copy button (teal) -->
        <Style x:Key="CopyButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Background" Value="#00796B"/>
            <Setter Property="Padding" Value="7,3"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="CellTextBox" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="CellTextBlock" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="ColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E8EAED"/>
            <Setter Property="Foreground" Value="#3C4043"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="BorderThickness" Value="0,0,1,2"/>
            <Setter Property="BorderBrush" Value="#DADCE0"/>
        </Style>

        <Style x:Key="CellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8F0FE"/>
                    <Setter Property="Foreground" Value="#1A1A1A"/>
                </Trigger>
                <Trigger Property="IsEditing" Value="True">
                    <Setter Property="Background" Value="#FFF8E1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Grid.Row="0" Background="#00796B" Padding="12,7">
            <DockPanel>
                <TextBlock Text="📋" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Clipper"
                           Foreground="White"
                           FontFamily="Consolas"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Click Copy to put file contents on the clipboard"
                           Foreground="#B2DFDB"
                           FontFamily="Consolas"
                           FontSize="10"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1"
                Background="#F8F9FA"
                BorderThickness="0,0,0,1"
                BorderBrush="#DADCE0"
                Padding="8,5">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="+ Add Row"
                            Style="{StaticResource AddButton}"
                            Click="AddRow_Click"/>
                    <Button Content="&#x2212; Remove Row"
                            Style="{StaticResource RemoveButton}"
                            Click="RemoveRow_Click"/>
                    <Rectangle Width="1" Fill="#DADCE0" Margin="6,3"/>
                    <Button Content="&#x1F4BE; Save"
                            Style="{StaticResource SaveButton}"
                            Click="Save_Click"
                            ToolTip="Save (also saves automatically on close)"/>
                </StackPanel>
                <TextBlock Text="Double-click any cell to edit."
                           Foreground="#888"
                           FontFamily="Consolas"
                           FontSize="10"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2"
                  x:Name="ClipGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CanUserResizeRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#EEEEEE"
                  RowHeight="28"
                  SelectionUnit="FullRow"
                  SelectionMode="Single"
                  Background="White"
                  AlternatingRowBackground="#FAFAFA"
                  BorderThickness="0"
                  ColumnHeaderStyle="{StaticResource ColumnHeaderStyle}"
                  CellStyle="{StaticResource CellStyle}"
                  IsReadOnly="False"
                  PreviewMouseLeftButtonDown="DataGrid_PreviewMouseLeftButtonDown">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#F0F0F0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#E8F0FE"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F1F3F4"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>

                <!-- Column 1: Label -->
                <DataGridTemplateColumn Header="Label" Width="180" SortMemberPath="Label">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}"
                                       Style="{StaticResource CellTextBlock}"
                                       ToolTip="Double-click to rename"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource CellTextBox}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Source file path (editable for configuration) -->
                <DataGridTemplateColumn Header="Source File" Width="*" SortMemberPath="FilePath">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FilePath}"
                                       Style="{StaticResource CellTextBlock}"
                                       ToolTip="{Binding FilePath}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource CellTextBox}"
                                     ToolTip="{Binding FilePath}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Column 2: Copy button -->
                <DataGridTemplateColumn Header="Action" Width="90" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="📋 Copy"
                                    Style="{StaticResource CopyButton}"
                                    Click="Copy_Click"
                                    Tag="{Binding}"
                                    Margin="4,2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Status bar -->
        <Border Grid.Row="3"
                Background="#F1F3F4"
                BorderThickness="0,1,0,0"
                BorderBrush="#DADCE0"
                Padding="10,3">
            <DockPanel>
                <TextBlock x:Name="StatusIcon" Text="&#x2713;" Foreground="#107C10"
                           FontFamily="Consolas" FontWeight="Bold" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Text="Ready"
                           FontFamily="Consolas" Foreground="#5F6368" FontSize="10" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

    </Grid>
</Window>
